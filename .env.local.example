# ─────────────────────────────────────────────────────────────
# Pretty Good Stuff — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase (add when Compass build begins) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (add when Compass build begins) ────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Claude API (add when Compass build begins) ────────────────
ANTHROPIC_API_KEY=

# ── Contact / Business (update before launch) ─────────────────
# NEXT_PUBLIC_CONTACT_EMAIL=hello@prettygoodstuff.co
# NEXT_PUBLIC_WHATSAPP_NUMBER=+1XXXXXXXXXX
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/prettygoodstuff/30min
